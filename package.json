{
  "name": "compass-consult-website",
  "version": "1.0.0",
  "description": "Professional website for Compass Consult (Employability & Skills) Ltd",
  "author": "Zenith IT",
  "license": "MIT",
  "keywords": [
    "employability",
    "skills training",
    "career consultancy",
    "recruitment"
  ],
  "homepage": "https://compassconsult.co.uk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jake-Gibbons/Compass-Consult-Website"
  },
  "scripts": {
    "dev": "http-server",
    "serve": "http-server -p 8000 -c-1",
    "build": "npm run build:css && npm run build:lucide && npm run build:assets",
    "optimize:images": "node scripts/optimize-images.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "sync:resources": "node scripts/sync-resources.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/tailwind.min.css --minify",
    "build:lucide": "node scripts/build-lucide.mjs",
    "build:assets": "node scripts/version-assets.mjs",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/tailwind.min.css --watch",
    "test": "echo 'Test script to be configured'",
    "lint": "npm run lint:js",
    "lint:js": "eslint \"js/**/*.js\"",
    "link-check": "node scripts/link-check.mjs",
    "check": "npm run lint && npm run link-check",
    "deploy": "echo 'Deploy script to be configured'"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "aos": "^2.3.4",
    "esbuild": "^0.27.4",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "http-server": "^14.1.1",
    "lighthouse": "^13.0.3",
    "lucide": "^1.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "dependencies": {
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.1.5"
  }
}
